extends layout.pug

block header
    h1 Overseer Application
    nav
        ul
            li: a(href="/") Dashboard
            li: a(href="/inventory").active Inventory
            li: a(href="/alerts") Alerts
            li: a(href="/settings") Settings

block content
  h1 Device Inventory
  div
    table
      thead
        tr
          th ID
          th Name
          th Status
      tbody
        each device in devices
          tr
            td= device.ID
            td= device.Name
            td= device.Status