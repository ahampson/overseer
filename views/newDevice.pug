extends layout.pug

block header
    h1 Overseer - Inventory
    nav
      ul
        li: a(href="/") Dashboard
      ul.active
        li: a(href="/inventory") Inventory
        li: a(href="/inventory/new").active Add New Device

block content
    h1 Add New Device
    p Use the form below to add a new device to the Overseer inventory. Fill in the required fields and click "Add Device" to submit the information. The new device will be added to the inventory and can be monitored through the application.
    form(action="/inventory/new" method="POST")
        div
            label(for="deviceName") Device Name:
            input(type="text" id="deviceName" name="deviceName" required)
        div
            label(for="ipaddress") IP Address:
            input(type="text" id="ipaddress" name="ipaddress" required)
        div
            button(type="submit") Add Device
    p Alternatively, you can upload a CSV file containing multiple devices to add them to the inventory at once. Use the form below to select and upload your device file. The CSV file should follow the specified format for successful processing.
    form(action="/inventory/upload" method="POST" enctype="multipart/form-data")
        a(href="/samplefile.csv") Sample CSV File for Upload
        div
            label(for="deviceFile") Upload Device File:
            input(type="file" id="deviceFile" name="deviceFile" accept=".csv" required)
        div
            button(type="submit") Upload File
    

